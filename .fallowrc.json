{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": [
    "src/lib/types.ts"
  ],
  "ignoreDependencies": [
    "eslint-config-next"
  ],
  "rules": {
    "unused-files": "error",
    "unused-exports": "warn",
    "unused-types": "off",
    "duplication": "warn",
    "complexity": "warn"
  }
}
